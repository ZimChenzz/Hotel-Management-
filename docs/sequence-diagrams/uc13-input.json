          "to": "cust",
          "label": "show updated booking",
          "msg_type": "return",
          "step": "5.1"
        }
      ],
      "else_condition": "extension not available",
      "else_messages": [
        {
          "from": "sys",
          "to": "ui",
          "label": "error: room not available for extension",
          "msg_type": "return",
          "step": "EF-1"
        },
        {
          "from": "ui",
          "to": "cust",
          "label": "show unavailable message",
          "msg_type": "return",
          "step": "EF-2"
        }
