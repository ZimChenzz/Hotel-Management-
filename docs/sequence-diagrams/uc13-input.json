      "step": "2.1"
    },
    {
      "type": "message",
      "from": "db",
      "to": "sys",
      "label": "availability result",
      "msg_type": "return",
      "step": "2.2"
    },
    {
      "type": "alt",
      "condition": "extension available",
      "messages": [
        {
          "from": "sys",
          "to": "sys",
          "label": "calculateAdditionalCost()",
          "msg_type": "sync",
          "step": "3"
        },
        {
          "from": "sys",
          "to": "db",
          "label": "updateBooking(newCheckout, newTotal)",
          "msg_type": "sync",
          "step": "4"
        },
        {
          "from": "db",
          "to": "sys",
          "label": "updated",
          "msg_type": "return",
          "step": "4.1"
        },
        {
          "from": "sys",
          "to": "ui",
          "label": "extension confirmed",
          "msg_type": "return",
