{
  "uc_id": "UC-06",
  "title": "UC-06: Change Password",
  "participants": [
    {
      "id": "cust",
      "name": "Customer"
    },
    {
      "id": "ui",
      "name": "ChangePasswordForm"
    },
    {
      "id": "sys",
      "name": "System"
    },
    {
      "id": "db",
      "name": "Database"
    }
  ],
  "elements": [
    {
      "type": "message",
      "from": "cust",
      "to": "ui",
      "label": "select change password",
      "msg_type": "sync",
      "step": "1"
    },
    {
      "type": "message",
      "from": "ui",
      "to": "cust",
      "label": "request current & new password",
      "msg_type": "return",
      "step": "2"
    },
    {
      "type": "message",
      "from": "cust",
      "to": "ui",
      "label": "enter current, new & confirm password",
      "msg_type": "sync",
      "step": "3"
    },
    {
      "type": "message",
      "from": "ui",
      "to": "sys",
      "label": "changePassword(current, new, confirm)",
      "msg_type": "sync",
      "step": "4"
    },
    {
      "type": "message",
      "from": "sys",
      "to": "db",
      "label": "verifyCurrentPassword()",
      "msg_type": "sync",
      "step": "4.1"
    },
    {
      "type": "message",
      "from": "db",
      "to": "sys",
      "label": "verification result",
      "msg_type": "return",
      "step": "4.2"
    },
    {
      "type": "alt",
      "condition": "current password correct & new valid",
      "messages": [
        {
          "from": "sys",
          "to": "db",
          "label": "updatePassword(hashedNewPwd)",
          "msg_type": "sync",
          "step": "5"
        },
        {
          "from": "db",
          "to": "sys",
          "label": "updated",
          "msg_type": "return",
          "step": "5.1"
        },
        {
          "from": "sys",
          "to": "ui",
          "label": "password changed successfully",
          "msg_type": "return",
          "step": "6"
        },
        {
          "from": "ui",
          "to": "cust",
          "label": "show success",
          "msg_type": "return",
          "step": "6.1"
        }
      ],
      "else_condition": "current password wrong or new invalid",
      "else_messages": [
        {
          "from": "sys",
          "to": "ui",
          "label": "error message",
          "msg_type": "return",
          "step": "EF-1"
        },
        {
          "from": "ui",
          "to": "cust",
          "label": "show error",
          "msg_type": "return",
          "step": "EF-2"
        }
      ]
    }
  ]
}