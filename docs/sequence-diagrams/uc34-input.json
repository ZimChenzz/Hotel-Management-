      "name": "Staff"
    },
    {
      "id": "ui",
      "name": "PaymentProcessPage"
    },
    {
      "id": "sys",
      "name": "System"
    },
    {
      "id": "pay",
      "name": "PaymentGateway"
    },
    {
      "id": "db",
      "name": "Database"
    }
  ],
  "elements": [
    {
      "type": "message",
      "from": "staff",
      "to": "ui",
      "label": "select booking & payment method",
      "msg_type": "sync",
      "step": "1"
    },
    {
      "type": "message",
      "from": "ui",
      "to": "sys",
      "label": "processPayment(bookingId, method, amount)",
      "msg_type": "sync",
      "step": "2"
    },
    {
