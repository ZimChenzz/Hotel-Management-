    {
      "type": "message",
      "from": "pay",
      "to": "sys",
      "label": "payment result",
      "msg_type": "return",
      "step": "3.1"
    },
    {
      "type": "message",
      "from": "sys",
      "to": "db",
      "label": "savePaymentRecord(bookingId, status)",
      "msg_type": "sync",
      "step": "4"
    },
    {
      "type": "message",
      "from": "db",
      "to": "sys",
      "label": "saved",
      "msg_type": "return",
      "step": "4.1"
    },
    {
      "type": "message",
      "from": "sys",
      "to": "ui",
      "label": "payment processed + receipt",
      "msg_type": "return",
      "step": "5"
    },
    {
      "type": "message",
      "from": "ui",
