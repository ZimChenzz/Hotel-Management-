{
  "uc_id": "UC-03",
  "title": "UC-03: Forgot Password",
  "participants": [
    {
      "id": "cust",
      "name": "Customer"
    },
    {
      "id": "ui",
      "name": "ForgotPasswordForm"
    },
    {
      "id": "sys",
      "name": "System"
    },
    {
      "id": "email",
      "name": "EmailService"
    }
  ],
  "elements": [
    {
      "type": "message",
      "from": "cust",
      "to": "ui",
      "label": "select forgot password",
      "msg_type": "sync",
      "step": "1"
    },
    {
      "type": "message",
      "from": "ui",
      "to": "cust",
      "label": "request registered email",
      "msg_type": "return",
      "step": "2"
    },
    {
      "type": "message",
      "from": "cust",
      "to": "ui",
      "label": "provide email",
      "msg_type": "sync",
      "step": "3"
    },
    {
      "type": "message",
      "from": "ui",
      "to": "sys",
      "label": "verifyEmail(email)",
      "msg_type": "sync",
      "step": "4"
    },
    {
      "type": "alt",
      "condition": "email exists",
      "messages": [
        {
          "from": "sys",
          "to": "sys",
          "label": "generate OTP",
          "msg_type": "sync",
          "step": "4.1"
        },
        {
          "from": "sys",
          "to": "email",
          "label": "sendOTP(email, otp)",
          "msg_type": "sync",
          "step": "5"
        },
        {
          "from": "email",
          "to": "sys",
          "label": "sent confirmation",
          "msg_type": "return",
          "step": "5.1"
        },
        {
          "from": "sys",
          "to": "ui",
          "label": "OTP sent successfully",
          "msg_type": "return",
          "step": "6"
        },
        {
          "from": "ui",
          "to": "cust",
          "label": "show OTP sent confirmation",
          "msg_type": "return",
          "step": "6.1"
        }
      ],
      "else_condition": "email not found",
      "else_messages": [
        {
          "from": "sys",
          "to": "ui",
          "label": "error: email not found",
          "msg_type": "return",
          "step": "EF-1"
        },
        {
          "from": "ui",
          "to": "cust",
          "label": "show error message",
          "msg_type": "return",
          "step": "EF-2"
        }
      ]
    }
  ]
}