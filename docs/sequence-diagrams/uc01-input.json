{
  "uc_id": "UC-01",
  "title": "UC-01: Register Account",
  "participants": [
    {
      "id": "guest",
      "name": "Guest"
    },
    {
      "id": "ui",
      "name": "RegisterForm"
    },
    {
      "id": "sys",
      "name": "System"
    },
    {
      "id": "db",
      "name": "Database"
    }
  ],
  "elements": [
    {
      "type": "message",
      "from": "guest",
      "to": "ui",
      "label": "select registration option",
      "msg_type": "sync",
      "step": "1"
    },
    {
      "type": "message",
      "from": "ui",
      "to": "guest",
      "label": "request personal info & password",
      "msg_type": "return",
      "step": "2"
    },
    {
      "type": "message",
      "from": "guest",
      "to": "ui",
      "label": "provide info (name, email, phone, address, password)",
      "msg_type": "sync",
      "step": "3"
    },
    {
      "type": "message",
      "from": "ui",
      "to": "sys",
      "label": "validate info & check email uniqueness",
      "msg_type": "sync",
      "step": "4"
    },
    {
      "type": "message",
      "from": "sys",
      "to": "db",
      "label": "checkEmailExists(email)",
      "msg_type": "sync",
      "step": "4.1"
    },
    {
      "type": "message",
      "from": "db",
      "to": "sys",
      "label": "email check result",
      "msg_type": "return",
      "step": "4.2"
    },
    {
      "type": "alt",
      "condition": "email unique & data valid",
      "messages": [
        {
          "from": "sys",
          "to": "db",
          "label": "createAccount(info, role=Customer)",
          "msg_type": "sync",
          "step": "5"
        },
        {
          "from": "db",
          "to": "sys",
          "label": "account created",
          "msg_type": "return",
          "step": "5.1"
        },
        {
          "from": "sys",
          "to": "ui",
          "label": "registration successful",
          "msg_type": "return",
          "step": "6"
        },
        {
          "from": "ui",
          "to": "guest",
          "label": "show success confirmation",
          "msg_type": "return",
          "step": "6.1"
        }
      ],
      "else_condition": "email exists or invalid data",
      "else_messages": [
        {
          "from": "sys",
          "to": "ui",
          "label": "error: email exists / invalid data",
          "msg_type": "return",
          "step": "EF-1"
        },
        {
          "from": "ui",
          "to": "guest",
          "label": "show error, request correction",
          "msg_type": "return",
          "step": "EF-2"
        }
      ]
    }
  ]
}